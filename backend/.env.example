# Google OAuth
# Get from: console.cloud.google.com → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Tavily — live web search
# Get from: app.tavily.com
TAVILY_API_KEY=

# AWS Bedrock — Claude Haiku 4.5
# IAM user needs bedrock:InvokeModel permission
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
BEDROCK_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# LangSmith tracing (optional — enables trace URLs per research run)
# Get from: smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=meetiq

# App
SECRET_KEY=                   # generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FRONTEND_URL=http://localhost:5173

# Guardrail tuning (defaults are fine for local dev)
TAVILY_MAX_SEARCHES=5
SCRAPER_TIMEOUT_S=5
TAVILY_TIMEOUT_S=10
RESEARCH_TIMEOUT_S=60
CB_FAIL_THRESHOLD=3
CB_RECOVERY_S=300
RATE_LIMIT_PER_MIN=10
LOG_LEVEL=INFO
